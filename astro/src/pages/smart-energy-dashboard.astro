---
import Topbar from "../components/dashboard/Topbar.astro";
import Sidebar from "../components/dashboard/Sidebar.astro";
import StatStrip from "../components/dashboard/StatStrip.astro";
import UnitsPanel from "../components/dashboard/UnitsPanel.astro";
import MapPanel from "../components/dashboard/MapPanel.astro";
import EnergyTrendChart from "../components/dashboard/EnergyTrendChart.astro";
import CostCO2Chart from "../components/dashboard/CostCO2Chart.astro";
import CO2ImpactCard from "../components/dashboard/CO2ImpactCard.astro";
import SmartInsightsCard from "../components/dashboard/SmartInsightsCard.astro";
import AlertsTable from "../components/dashboard/AlertsTable.astro";
import EfficiencyRanking from "../components/dashboard/EfficiencyRanking.astro";
import "../styles/dashboard.css";

---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Energy Monitoring & CO₂ Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@300;400;500;600;700;800;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
</head>
<body>
  <Topbar />
  
  <div class="body-wrap">
    <Sidebar />
    
    <main class="main">
      <StatStrip />
      
      <!-- MID ROW: Units + Map -->
      <div class="mid-row">
        <UnitsPanel />
        <MapPanel />
      </div>
      
      <!-- BOTTOM ROW 1: Charts + CO2 + Insights -->
      <div class="bottom-row">
        <EnergyTrendChart />
        <CostCO2Chart />
        <CO2ImpactCard />
        <SmartInsightsCard />
      </div>
      
      <!-- BOTTOM ROW 2: Alerts + Efficiency -->
      <div class="bottom-bot-row">
        <AlertsTable />
        <EfficiencyRanking />
      </div>
    </main>
  </div>
</body>
</html>

<script>
  // Tab interactions
  document.querySelectorAll('.vtab').forEach((t) => {
    t.addEventListener('click', () => {
      const parent = t.closest('.view-toggle');
      if (parent) {
        parent.querySelectorAll('.vtab').forEach((x) => x.classList.remove('active'));
        t.classList.add('active');
      }
    });
  });

  document.querySelectorAll('.chart-tabs').forEach((tabs) => {
    tabs.querySelectorAll('.ctab').forEach((t) => {
      t.addEventListener('click', () => {
        tabs.querySelectorAll('.ctab').forEach((x) => x.classList.remove('active'));
        t.classList.add('active');
      });
    });
  });

  // Navigation
  document.querySelectorAll('.nav-item').forEach((item) => {
    item.addEventListener('click', () => {
      document.querySelectorAll('.nav-item').forEach((i) => i.classList.remove('active'));
      item.classList.add('active');
    });
  });

  // Map node click
  const units = [
    { id: 1, status: 'online', pct: 78, power: 235, today: 4.32 },
    { id: 2, status: 'online', pct: 65, power: 180, today: 3.21 },
    { id: 3, status: 'online', pct: 92, power: 310, today: 5.20 },
    { id: 4, status: 'online', pct: 81, power: 245, today: 4.15 },
    { id: 5, status: 'warn', pct: 32, power: 120, today: 2.11 },
    { id: 6, status: 'online', pct: 73, power: 210, today: 4.01 },
    { id: 7, status: 'alert', pct: 18, power: 95, today: 1.02 },
    { id: 8, status: 'online', pct: 67, power: 175, today: 3.10 },
    { id: 9, status: 'online', pct: 90, power: 299, today: 5.05 },
    { id: 10, status: 'online', pct: 76, power: 220, today: 4.00 },
    { id: 11, status: 'online', pct: 83, power: 255, today: 4.55 },
    { id: 12, status: 'warn', pct: 25, power: 110, today: 1.85 },
    { id: 13, status: 'online', pct: 71, power: 205, today: 3.80 },
    { id: 14, status: 'online', pct: 88, power: 265, today: 4.90 },
    { id: 15, status: 'online', pct: 69, power: 190, today: 3.35 },
  ];

  document.querySelectorAll('.map-node').forEach((node) => {
    node.addEventListener('click', () => {
      const id = parseInt(node.textContent || '0');
      const u = units.find((x) => x.id === id);
      if (!u) return;
      
      const suName = document.querySelector('.su-name');
      const suBadge = document.querySelector('.su-badge');
      const suStatVals = document.querySelectorAll('.su-stat-val');
      
      if (suName) suName.textContent = 'Unit ' + u.id;
      if (suBadge) {
        const badge = suBadge as HTMLElement;
        const statusLabel = u.status === 'alert' ? 'Alert' : u.status === 'warn' ? 'Warning' : 'Online';
        badge.textContent = statusLabel;
        badge.style.background = u.status === 'alert' ? 'rgba(255,61,113,0.2)' : u.status === 'warn' ? 'rgba(255,215,64,0.2)' : 'rgba(0,230,118,0.2)';
        badge.style.color = u.status === 'alert' ? 'var(--red)' : u.status === 'warn' ? 'var(--yellow)' : 'var(--green)';
      }
      if (suStatVals.length >= 3) {
        suStatVals[0].textContent = u.pct + '%';
        suStatVals[1].textContent = u.power + ' W';
        suStatVals[2].textContent = u.today + ' kWh';
        const ac = u.status === 'alert' ? 'alert-c' : '';
        suStatVals.forEach((v) => {
          v.className = 'su-stat-val' + (ac ? ' ' + ac : '');
        });
      }
    });
  });
</script>

