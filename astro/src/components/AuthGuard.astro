---
// src/components/AuthGuard.astro
// This component can be used in any page that requires authentication
---
<div id="auth-guard-loading" style="display:flex;align-items:center;justify-content:center;min-height:100vh;color:#e2e8f0;font-family:Arial,sans-serif;">
  <div style="text-align:center;">
    <div style="font-size:2rem;margin-bottom:1rem;">⚡</div>
    <div>Checking authentication...</div>
  </div>
</div>

<script>
  (function () {
    try {
      const token = localStorage.getItem("auth_token");
      const userStr = localStorage.getItem("user");

      // Check if both token and user data exist
      if (!token || !userStr) {
        console.log('No auth token or user data found');
        localStorage.clear();
        window.location.replace("/auth/login");
        return;
      }

      // Validate user JSON
      try {
        const userData = JSON.parse(userStr);
        if (!userData || typeof userData !== 'object') {
          throw new Error('Invalid user data');
        }
      } catch (e) {
        console.error('Invalid user data in localStorage');
        localStorage.clear();
        window.location.replace("/auth/login");
        return;
      }

      // Check token expiration
      const tokenExpires = localStorage.getItem("auth_token_expires");
      if (tokenExpires) {
        const expiresAt = parseInt(tokenExpires, 10);
        if (!Number.isNaN(expiresAt) && Date.now() > expiresAt) {
          console.log('Auth token expired');
          localStorage.clear();
          window.location.replace("/auth/login");
          return;
        }
      }

      // Optional: Validate token format (basic check)
      if (token.split('.').length !== 3) {
        console.error('Invalid token format');
        localStorage.clear();
        window.location.replace("/auth/login");
        return;
      }

      // Authentication successful - hide loading
      const loadingEl = document.getElementById("auth-guard-loading");
      if (loadingEl) {
        loadingEl.style.display = "none";
      }
    } catch (err) {
      console.error('Auth guard error:', err);
      localStorage.clear();
      window.location.replace("/auth/login");
    }
  })();
</script>