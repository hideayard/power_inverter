---
// StatCard.astro
export interface Props {
  icon?: string;
  iconClass?: string;
  label: string;
  change?: string;
  changeClass?: string;
  iconImage?: string;
}

const {
  icon,
  iconClass = "",
  label,
  change,
  changeClass = "",
  iconImage
} = Astro.props;
---

<div class="stat-card card h-100">
  <div class="card-body d-flex align-items-start gap-3">
    <div class={`stat-icon ${iconClass} d-flex align-items-center justify-content-center rounded-3`}>
      {
        iconImage ? (
          <img src={iconImage} alt={label} class="stat-icon-img" />
        ) : (
          <span>{icon}</span>
        )
      }
    </div>

    <div class="stat-content flex-grow-1">
      <div class="stat-label small text-muted text-uppercase fw-bold">{label}</div>

      <div class="stat-value fs-5 fw-bold">
        <slot name="value" />
      </div>

      <div class="stat-bottom small">
        <slot name="sub" />

        {
          change && (
            <div class={`stat-change ${changeClass} badge bg-success-subtle text-success`}>
              {change}
            </div>
          )
        }
      </div>
    </div>
  </div>
</div>