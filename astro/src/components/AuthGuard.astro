<div id="auth-guard-loading" style="display:flex;align-items:center;justify-content:center;min-height:100vh;color:#e2e8f0;font-family:Arial,sans-serif;">
  Checking authentication...
</div>

<script>
  (function () {
    try {
      const token = localStorage.getItem("jwt");
      const userStr = localStorage.getItem("user");

      if (!token || !userStr) {
        location.replace("http://localhost/inverter/auth/login.php");
        return;
      }

      try {
        JSON.parse(userStr);
      } catch (e) {
        localStorage.clear();
        location.replace("http://localhost/inverter/auth/login.php");
        return;
      }

      const tokenExpires = localStorage.getItem("jwt_expires");
      if (tokenExpires) {
        const expiresAt = parseInt(tokenExpires);
        if (!Number.isNaN(expiresAt) && Date.now() > expiresAt) {
          localStorage.clear();
          location.replace("http://localhost/inverter/auth/login.php");
          return;
        }
      }

      const loadingEl = document.getElementById("auth-guard-loading");
      if (loadingEl) loadingEl.style.display = "none";
    } catch (err) {
      location.replace("http://localhost/inverter/auth/login.php");
    }
  })();
</script>
