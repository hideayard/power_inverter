<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lupa Kata Laluan - Geran Komuniti Iskandar Puteri Rendah Karbon 5.0</title>

  <link rel="icon" type="image/png" href="/assets/images/favicon.png" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg,#EDF2F7 0%,#FFFFFF 100%); min-height:100vh; display:flex; align-items:center; justify-content:center; padding:1rem; }
    .forgot-container { max-width:1200px; width:100%; display:grid; grid-template-columns:1.2fr 0.8fr; background:#fff; border-radius:2rem; overflow:hidden; border:2px solid #FDA300; }
    .brand-side { background: linear-gradient(135deg,#2C5282 0%,#1A2B3E 100%); padding:2rem; min-height:700px; color:#fff; display:flex; flex-direction:column; }
    .form-side { padding:2.5rem 2rem; display:flex; flex-direction:column; justify-content:center; }
    .form-header h2 { color:#2C5282; font-size:1.75rem; font-weight:700; margin-bottom:.5rem; }
    .form-header p { color:#315492; font-size:.9rem; }
    .forgot-form { max-width:340px; margin:0 auto; width:100%; }
    .form-group { margin-bottom:1.5rem; }
    .form-label { display:block; color:#2C5282; font-size:.875rem; font-weight:600; margin-bottom:.4rem; }
    .input-group { position:relative; display:flex; align-items:center; }
    .input-icon { position:absolute; left:1rem; color:#2C5282; }
    .form-input { width:100%; padding:.75rem 1rem .75rem 2.75rem; border:2px solid #EDF2F7; border-radius:.75rem; background:#F8FAFC; color:#2C5282; }
    .reset-button { width:100%; padding:.875rem; background:linear-gradient(135deg,#2C5282,#1A2B3E); color:#fff; border:none; border-radius:.75rem; font-weight:600; cursor:pointer; }
    .login-link { text-align:center; margin-top:1rem; }
    .login-link a { color:#2C5282; text-decoration:none; }
    @media (max-width:768px){ .forgot-container{grid-template-columns:1fr;max-width:500px;} .brand-side{display:none;} }
  </style>
</head>
<body>
  <div class="forgot-container">
    <div class="brand-side">
      <h1>Geran Komuniti Iskandar Puteri Rendah Karbon 5.0</h1>
      <p>Sistem pemantauan projek Pasar Malam Hijau</p>
    </div>

    <div class="form-side">
      <div class="form-header">
        <h2>Lupa Kata Laluan?</h2>
        <p>Masukkan email anda untuk menerima pautan reset.</p>
      </div>

      <form class="forgot-form" id="forgotForm">
        <div class="form-group">
          <label class="form-label" for="email">Alamat Email</label>
          <div class="input-group">
            <i class="fas fa-envelope input-icon"></i>
            <input type="email" id="email" class="form-input" placeholder="nama@email.com" required />
          </div>
        </div>

        <button type="submit" class="reset-button" id="resetButton">
          <i class="fas fa-paper-plane"></i> Hantar Pautan Reset
        </button>

        <div class="login-link">
          <a href="/auth/login"><i class="fas fa-sign-in-alt"></i> Kembali ke Log Masuk</a>
        </div>
      </form>
    </div>
  </div>

  <script src="/assets/js/auth.js"></script>
  <script is:inline>
    // @ts-nocheck
    document.addEventListener('DOMContentLoaded', function () {
      const forgotForm = document.getElementById('forgotForm');
      const resetButton = document.getElementById('resetButton');
      const emailInput = document.getElementById('email');
      if (!forgotForm || !resetButton || !emailInput) return;

      forgotForm.addEventListener('submit', async function (e) {
        e.preventDefault();
        const email = emailInput.value.trim();
        if (!email) return;

        const original = resetButton.innerHTML;
        resetButton.disabled = true;
        resetButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Menghantar...';

        try {
          await window.forgotPassword(email);
        } catch (err) {
          resetButton.disabled = false;
          resetButton.innerHTML = original;
        }
      });
    });
  </script>
</body>
</html>
