---
// StatStrip.astro
import StatCard from "./StatCard.astro";
---

<div class="stat-strip">
  <StatCard
    icon="↻"
    iconClass="si-blue"
    label="TOTAL UNITS"
  >
    <Fragment slot="value">
      15
    </Fragment>

    <div slot="sub" class="stat-sub">
      <span>Online: 15</span>
      <span>Offline: 0</span>
    </div>
  </StatCard>

  <StatCard
    icon="⚡"
    iconClass="si-green"
    label="TOTAL ENERGY TODAY"
    change="↑ 8.72%"
    changeClass="up"
  >
    <Fragment slot="value">
      78.62 <span class="unit">kWh</span>
    </Fragment>

    <div slot="sub" class="stat-sub">
      Yesterday: 72.31 kWh
    </div>
  </StatCard>

  <StatCard
    icon="$"
    iconClass="si-yellow"
    label="TOTAL COST SAVED TODAY"
    change="↑ 8.83%"
    changeClass="up"
  >
    <Fragment slot="value">
      RM 138.45
    </Fragment>

    <div slot="sub" class="stat-sub">
      Yesterday: RM 127.20
    </div>
  </StatCard>

  <StatCard
    icon="🍃"
    iconClass="si-purple"
    label="TOTAL CO₂ REDUCED TODAY"
  >
    <Fragment slot="value">
      78.45 <span class="unit">kg</span>
    </Fragment>

    <div slot="sub" class="stat-sub">
      All Time: 1,562.34 kg
    </div>
  </StatCard>

  <StatCard
    icon="↗"
    iconClass="si-cyan"
    label="AVG. EFFICIENCY SCORE"
  >
    <Fragment slot="value">
      86<span class="unit"> /100</span>
    </Fragment>

    <div slot="sub" class="stat-sub stat-good">
      Good
    </div>
  </StatCard>
</div>