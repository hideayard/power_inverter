---
// src/pages/auth/login.astro
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Geran Komuniti Iskandar Puteri Rendah Karbon 5.0</title>

    <link rel="icon" type="image/png" href="/assets/images/favicon.png" />

    <!-- Google Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
      :root {
        --primary: #2C5282;
        --primary-dark: #1A2B3E;
        --accent: #FDA300;
        --accent-light: #FFB830;
        --success: #10B981;
        --danger: #EF4444;
        --white: #FFFFFF;
        --gray-50: #F8FAFC;
        --gray-100: #F1F5F9;
        --gray-200: #E2E8F0;
        --gray-400: #94A3B8;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1E293B;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
        --shadow-md: 0 4px 6px rgba(0,0,0,0.1);
        --shadow-lg: 0 10px 40px rgba(0,0,0,0.15);
        --shadow-xl: 0 20px 60px rgba(0,0,0,0.2);
        --radius-sm: 0.75rem;
        --radius-md: 1rem;
        --radius-lg: 1.5rem;
        --radius-xl: 2rem;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
        min-height: 100vh;
        background: linear-gradient(160deg, #0F172A 0%, #1A2B3E 30%, #2C5282 70%, #1A2B3E 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        position: relative;
        overflow-x: hidden;
      }

      /* Animated Background */
      .bg-particles {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
      }

      .particle {
        position: absolute;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(253,163,0,0.3), transparent);
        animation: floatParticle 15s infinite ease-in-out;
      }
      .particle:nth-child(1) { width: 300px; height: 300px; top: -100px; left: -50px; animation-delay: 0s; }
      .particle:nth-child(2) { width: 200px; height: 200px; top: 50%; right: -80px; animation-delay: 3s; }
      .particle:nth-child(3) { width: 250px; height: 250px; bottom: -120px; left: 30%; animation-delay: 6s; }
      .particle:nth-child(4) { width: 180px; height: 180px; top: 20%; right: 30%; animation-delay: 9s; }
      .particle:nth-child(5) { width: 150px; height: 150px; bottom: 10%; right: 10%; animation-delay: 12s; }

      @keyframes floatParticle {
        0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.3; }
        25% { transform: translate(50px, -30px) scale(1.2); opacity: 0.5; }
        50% { transform: translate(-30px, 50px) scale(0.8); opacity: 0.2; }
        75% { transform: translate(-50px, -20px) scale(1.1); opacity: 0.4; }
      }

      /* Grid Pattern Overlay */
      .grid-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: 
          linear-gradient(rgba(253,163,0,0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(253,163,0,0.03) 1px, transparent 1px);
        background-size: 50px 50px;
        z-index: 0;
        pointer-events: none;
      }

      /* Main Card */
      .login-card {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 1100px;
        display: flex;
        background: rgba(255,255,255,0.98);
        backdrop-filter: blur(20px);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-xl), 0 0 0 1px rgba(253,163,0,0.2);
        overflow: hidden;
      }

      /* Brand Panel */
      .brand-panel {
        flex: 0 0 55%;
        background: linear-gradient(145deg, #1A2B3E 0%, #2C5282 50%, #1A365D 100%);
        padding: 3rem;
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        color: white;
      }

      .brand-panel::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle, rgba(253,163,0,0.1) 0%, transparent 70%);
        animation: pulse 4s ease-in-out infinite;
      }

      .brand-panel::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -30%;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle, rgba(253,163,0,0.08) 0%, transparent 70%);
        animation: pulse 4s ease-in-out infinite 2s;
      }

      @keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 0.5; }
        50% { transform: scale(1.3); opacity: 0.8; }
      }

      .brand-content { position: relative; z-index: 1; }

      .brand-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 50px;
        padding: 0.5rem 1.25rem;
        margin-bottom: 2rem;
        font-size: 0.85rem;
        font-weight: 500;
      }

      .brand-icon {
        width: 40px;
        height: 40px;
        background: var(--accent);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        box-shadow: 0 4px 15px rgba(253,163,0,0.4);
      }

      .brand-title {
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 1rem;
        letter-spacing: -0.5px;
      }
      .brand-title .highlight {
        background: linear-gradient(135deg, #FDA300, #FFB830);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .brand-subtitle {
        font-size: 1.05rem;
        color: rgba(255,255,255,0.8);
        line-height: 1.6;
        margin-bottom: 2.5rem;
      }

      .feature-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        margin-bottom: 2rem;
      }

      .feature-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: rgba(255,255,255,0.06);
        border-radius: var(--radius-sm);
        border: 1px solid rgba(255,255,255,0.1);
        transition: all 0.3s ease;
      }
      .feature-item:hover {
        background: rgba(255,255,255,0.12);
        transform: translateX(5px);
        border-color: rgba(253,163,0,0.3);
      }
      .feature-icon {
        font-size: 1.25rem;
        width: 35px;
        height: 35px;
        background: rgba(253,163,0,0.15);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .feature-text {
        font-size: 0.85rem;
        font-weight: 500;
      }

      .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.1);
      }
      .stat-item { text-align: center; }
      .stat-number {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--accent);
      }
      .stat-label {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.6);
        margin-top: 0.25rem;
      }

      /* Form Panel */
      .form-panel {
        flex: 0 0 45%;
        padding: 3rem 2.5rem;
        display: flex;
        align-items: center;
        background: linear-gradient(135deg, #FFFFFF 0%, #F8FAFC 100%);
      }

      .form-wrapper { width: 100%; }

      .form-header {
        text-align: center;
        margin-bottom: 2rem;
      }
      .form-header .welcome-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        display: block;
        animation: bounce 2s ease-in-out infinite;
      }
      @keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
      }
      .form-header h2 {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--gray-800);
        margin-bottom: 0.25rem;
      }
      .form-header p {
        color: var(--gray-400);
        font-size: 0.9rem;
      }
      .form-header a {
        color: var(--accent);
        font-weight: 600;
        text-decoration: none;
        transition: color 0.2s;
      }
      .form-header a:hover { color: var(--accent-light); }

      .input-group {
        position: relative;
        margin-bottom: 1.25rem;
      }
      .input-group .input-icon {
        position: absolute;
        left: 1.125rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        font-size: 1rem;
        transition: all 0.3s ease;
        z-index: 2;
        pointer-events: none;
      }
      .input-group input {
        width: 100%;
        padding: 0.875rem 1rem 0.875rem 2.75rem;
        background: var(--gray-50);
        border: 2px solid var(--gray-200);
        border-radius: var(--radius-md);
        font-size: 0.95rem;
        color: var(--gray-800);
        transition: all 0.3s ease;
        outline: none;
        font-family: inherit;
      }
      .input-group input:focus {
        background: white;
        border-color: var(--accent);
        box-shadow: 0 0 0 4px rgba(253,163,0,0.08);
      }
      .input-group input:focus ~ .input-icon {
        color: var(--accent);
      }
      .input-group input::placeholder {
        color: var(--gray-400);
      }

      .toggle-password {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: var(--gray-400);
        cursor: pointer;
        font-size: 1.1rem;
        padding: 0.25rem;
        z-index: 2;
        transition: color 0.3s;
      }
      .toggle-password:hover { color: var(--accent); }

      .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
      }
      .checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: var(--gray-600);
        cursor: pointer;
      }
      .checkbox-label input[type="checkbox"] {
        width: 1.1rem;
        height: 1.1rem;
        accent-color: var(--accent);
        cursor: pointer;
      }
      .forgot-link {
        font-size: 0.85rem;
        color: var(--accent);
        font-weight: 600;
        text-decoration: none;
        transition: color 0.2s;
      }
      .forgot-link:hover { color: var(--accent-light); }

      .btn-login {
        width: 100%;
        padding: 0.938rem;
        background: linear-gradient(135deg, var(--primary-dark), var(--primary));
        color: white;
        border: none;
        border-radius: var(--radius-md);
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        font-family: inherit;
        letter-spacing: 0.3px;
      }
      .btn-login::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
        transition: left 0.5s;
      }
      .btn-login:hover::before { left: 100%; }
      .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(44,82,130,0.4);
        border-color: var(--accent);
      }
      .btn-login:active { transform: translateY(0); }
      .btn-login:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
      }
      .btn-login .btn-content {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
      }

      .spinner {
        width: 20px;
        height: 20px;
        border: 2.5px solid rgba(255,255,255,0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      .register-link {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.875rem;
        color: var(--gray-400);
      }
      .register-link a {
        color: var(--accent);
        font-weight: 600;
        text-decoration: none;
      }
      .register-link a:hover { text-decoration: underline; }

      /* Responsive Design */
      @media (max-width: 900px) {
        body { padding: 1rem; align-items: flex-start; padding-top: 2rem; }
        .login-card {
          flex-direction: column;
          max-width: 450px;
        }
        .brand-panel {
          flex: auto;
          padding: 2rem 1.5rem;
        }
        .brand-title { font-size: 1.75rem; }
        .brand-subtitle { font-size: 0.9rem; margin-bottom: 1.5rem; }
        .feature-grid { gap: 0.5rem; }
        .feature-item { padding: 0.5rem 0.75rem; }
        .feature-text { font-size: 0.78rem; }
        .stats-row { padding-top: 1rem; }
        .form-panel {
          flex: auto;
          padding: 2rem 1.5rem;
        }
      }

      @media (max-width: 480px) {
        body { padding: 0.75rem; padding-top: 1.5rem; }
        .login-card { border-radius: var(--radius-lg); }
        .brand-panel { padding: 1.5rem 1.25rem; display: none; }
        .brand-title { font-size: 1.5rem; }
        .form-panel { padding: 1.75rem 1.25rem; }
        .form-header h2 { font-size: 1.5rem; }
        .input-group input { padding: 0.75rem 1rem 0.75rem 2.5rem; font-size: 0.9rem; }
        .btn-login { padding: 0.813rem; }
      }
    </style>
  </head>

  <body>
    <!-- Animated Background -->
    <div class="bg-particles">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>
    <div class="grid-overlay"></div>

    <!-- Login Card -->
    <div class="login-card">
      <!-- Brand Panel -->
      <div class="brand-panel">
        <div class="brand-content">
          <div class="brand-badge">
            <div class="brand-icon">⚡</div>
            <span>Inverter 2.0</span>
          </div>

          <h1 class="brand-title">
            Geran Komuniti<br />
            <span class="highlight">Iskandar Puteri</span>
          </h1>
          <p class="brand-subtitle">
            Sistem pemantauan projek Pasar Malam Hijau yang dikuasakan oleh
            Power Inverter 2.0 untuk masa depan yang lebih lestari dan rendah karbon.
          </p>

          <div class="feature-grid">
            <div class="feature-item">
              <div class="feature-icon">🌱</div>
              <span class="feature-text">Pemantauan Karbon</span>
            </div>
            <div class="feature-item">
              <div class="feature-icon">📊</div>
              <span class="feature-text">Dashboard Interaktif</span>
            </div>
            <div class="feature-item">
              <div class="feature-icon">🏪</div>
              <span class="feature-text">Pasar Malam Hijau</span>
            </div>
            <div class="feature-item">
              <div class="feature-icon">🔋</div>
              <span class="feature-text">Tenaga Diperbaharui</span>
            </div>
          </div>

          <div class="stats-row">
            <div class="stat-item">
              <div class="stat-number">5.0</div>
              <div class="stat-label">Versi Terkini</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">10+</div>
              <div class="stat-label">Komuniti</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">24/7</div>
              <div class="stat-label">Pemantauan</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Form Panel -->
      <div class="form-panel">
        <div class="form-wrapper">
          <div class="form-header">
            <span class="welcome-icon">🌿</span>
            <h2>Selamat Datang!</h2>
            <p>Atau <a href="/auth/register">daftar akaun baru</a></p>
          </div>

          <form id="loginForm">
            <div class="input-group">
              <span class="input-icon"><i class="fas fa-user"></i></span>
              <input
                type="text"
                id="username"
                name="username"
                placeholder="Username"
                required
                autocomplete="username"
              />
            </div>

            <div class="input-group">
              <span class="input-icon"><i class="fas fa-lock"></i></span>
              <input
                type="password"
                id="password"
                name="password"
                placeholder="Kata Laluan"
                required
                autocomplete="current-password"
              />
              <button type="button" class="toggle-password" id="togglePassword" tabindex="-1">
                <i class="fas fa-eye"></i>
              </button>
            </div>

            <div class="form-options">
              <label class="checkbox-label">
                <input type="checkbox" id="remember" name="remember" />
                <span>Ingat saya</span>
              </label>
              <a href="/auth/forgot-password" class="forgot-link">Lupa Kata Laluan?</a>
            </div>

            <button type="submit" class="btn-login" id="loginButton">
              <span class="btn-content">
                <i class="fas fa-sign-in-alt"></i> Log Masuk
              </span>
            </button>
          </form>

          <p class="register-link">
            Belum ada akaun? <a href="/auth/register">Daftar sekarang →</a>
          </p>
        </div>
      </div>
    </div>

    <script>
      import "../../lib/login";
    </script>
  </body>
</html>