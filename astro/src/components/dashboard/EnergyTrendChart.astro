---
// Data for different time periods
const chartData = {
  today: {
    labels: ['12AM', '2AM', '4AM', '6AM', '8AM', '10AM', '12PM', '2PM', '4PM', '6PM', '8PM', '10PM'],
    energy: [3.2, 2.8, 2.1, 2.5, 4.2, 5.8, 6.5, 7.2, 6.8, 7.5, 8.1, 6.2],
    cost: [5.5, 4.8, 3.6, 4.3, 7.2, 9.9, 11.1, 12.3, 11.6, 12.8, 13.9, 10.6]
  },
  week: {
    labels: ['14 May', '15 May', '16 May', '17 May', '18 May', '19 May', '20 May'],
    energy: [68.5, 72.3, 65.8, 71.2, 74.6, 70.9, 78.62],
    cost: [118.2, 124.5, 112.8, 122.3, 128.5, 121.7, 138.45]
  },
  month: {
    labels: Array.from({length: 30}, (_, i) => `${i + 1} May`),
    energy: Array.from({length: 30}, () => Math.random() * 30 + 50),
    cost: Array.from({length: 30}, () => Math.random() * 50 + 90)
  }
};
---

<div class="chart-card card h-100" id="energyTrendChart">
  <div class="card-header"
    <div class="panel-title">ENERGY TREND (ALL UNITS)</div>
    <div class="chart-tabs btn-group btn-group-sm" role="group">
      <button type="button" class="ctab btn btn-outline-secondary" data-period="today">Today</button>
      <button type="button" class="ctab btn btn-dark active" data-period="week">7 Days</button>
      <button type="button" class="ctab btn btn-outline-secondary" data-period="month">30 Days</button>
    </div>
  </div>
  <div class="chart-area">
    <canvas id="energyChart"></canvas>
  </div>
  <div class="chart-legend">
    <div class="cl-item">
      <div class="cl-line" style="background:#4488ff"></div> 
      Total Energy (kWh)
    </div>
    <div class="cl-item">
      <div class="cl-line" style="background:#00e676;height:0;border-top:2px dashed #00e676"></div> 
      Total Cost (RM)
    </div>
  </div>
</div>

<script>
  import Chart from 'chart.js/auto';

  const chartData = {
    today: {
      labels: ['12AM', '2AM', '4AM', '6AM', '8AM', '10AM', '12PM', '2PM', '4PM', '6PM', '8PM', '10PM'],
      energy: [3.2, 2.8, 2.1, 2.5, 4.2, 5.8, 6.5, 7.2, 6.8, 7.5, 8.1, 6.2],
      cost: [5.5, 4.8, 3.6, 4.3, 7.2, 9.9, 11.1, 12.3, 11.6, 12.8, 13.9, 10.6]
    },
    week: {
      labels: ['14 May', '15 May', '16 May', '17 May', '18 May', '19 May', '20 May'],
      energy: [68.5, 72.3, 65.8, 71.2, 74.6, 70.9, 78.62],
      cost: [118.2, 124.5, 112.8, 122.3, 128.5, 121.7, 138.45]
    },
    month: {
      labels: Array.from({length: 30}, (_, i) => `${i + 1} May`),
      energy: Array.from({length: 30}, () => +(Math.random() * 30 + 50).toFixed(1)),
      cost: Array.from({length: 30}, () => +(Math.random() * 50 + 90).toFixed(2))
    }
  };

  const ctx = document.getElementById('energyChart');
  let currentChart: Chart;

  function createChart(period: 'today' | 'week' | 'month') {
    const data = chartData[period];
    
    if (currentChart) {
      currentChart.destroy();
    }

    currentChart = new Chart(ctx as HTMLCanvasElement, {
      type: 'line',
      data: {
        labels: data.labels,
        datasets: [
          {
            label: 'Total Energy (kWh)',
            data: data.energy,
            borderColor: '#4488ff',
            backgroundColor: 'rgba(68, 136, 255, 0.1)',
            borderWidth: 2,
            fill: true,
            tension: 0.4,
            pointRadius: 4,
            pointBackgroundColor: '#4488ff',
            pointBorderColor: '#ffffff',
            pointBorderWidth: 2,
            pointHoverRadius: 6,
          },
          {
            label: 'Total Cost (RM)',
            data: data.cost,
            borderColor: '#00e676',
            backgroundColor: 'rgba(0, 230, 118, 0.05)',
            borderWidth: 2,
            borderDash: [5, 5],
            fill: true,
            tension: 0.4,
            pointRadius: 4,
            pointBackgroundColor: '#00e676',
            pointBorderColor: '#ffffff',
            pointBorderWidth: 2,
            pointHoverRadius: 6,
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false,
        },
        plugins: {
          legend: {
            display: false, // We use custom legend
          },
          tooltip: {
            backgroundColor: '#111827',
            titleColor: '#00d4ff',
            bodyColor: '#e2e8f0',
            borderColor: '#243352',
            borderWidth: 1,
            padding: 12,
            displayColors: true,
            callbacks: {
              label: function(context) {
                let label = context.dataset.label || '';
                if (label) {
                  label += ': ';
                }
                if (context.datasetIndex === 0) {
                  label += context.parsed.y + ' kWh';
                } else {
                  label += 'RM ' + context.parsed.y;
                }
                return label;
              }
            }
          }
        },
        scales: {
          x: {
            grid: {
              color: 'rgba(255, 255, 255, 0.05)',
            },
            ticks: {
              color: 'rgba(255, 255, 255, 0.3)',
              font: {
                size: 9,
                family: "'Exo 2', sans-serif"
              }
            }
          },
          y: {
            grid: {
              color: 'rgba(255, 255, 255, 0.05)',
            },
            ticks: {
              color: 'rgba(255, 255, 255, 0.3)',
              font: {
                size: 9,
                family: "'Share Tech Mono', monospace"
              },
              callback: function(value) {
                return value + (this as any).chart.data.datasets[0].label?.includes('kWh') ? '' : '';
              }
            }
          }
        }
      }
    });
  }

  // Initialize with week data
  createChart('week');

  // Tab switching
  document.querySelectorAll('#energyTrendChart .ctab').forEach(tab => {
    tab.addEventListener('click', () => {
      const parent = tab.closest('#energyTrendChart');
      parent?.querySelectorAll('.ctab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      
      const period = tab.getAttribute('data-period') as 'today' | 'week' | 'month';
      createChart(period);
    });
  });
</script>

<style>
  .chart-card {
    background: var(--card, #111827);
    border: 1px solid var(--border, #1e2d47);
    border-radius: var(--r, 10px);
    padding: 14px;
    display: flex;
    flex-direction: column;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .panel-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--text, #e2e8f0);
    letter-spacing: 0.01em;
  }

  .chart-tabs {
    display: flex;
    gap: 4px;
  }

  .ctab {
    font-size: 10px;
    font-weight: 600;
    padding: 4px 9px;
    border-radius: var(--r-sm, 6px);
    border: 1px solid transparent;
    cursor: pointer;
    background: transparent;
    color: var(--text3, #4a6080);
    font-family: var(--font, 'Exo 2', sans-serif);
    transition: all 0.2s;
  }

  .ctab.active {
    background: var(--blue, #4488ff);
    color: #fff;
    border-color: var(--blue, #4488ff);
  }

  .ctab:not(.active):hover {
    color: var(--text2, #8fa3bf);
    border-color: var(--border, #1e2d47);
  }

  .chart-area {
    flex: 1;
    min-height: 200px;
    position: relative;
  }

  .chart-legend {
    display: flex;
    gap: 14px;
    margin-top: 8px;
    flex-wrap: wrap;
  }

  .cl-item {
    font-size: 10px;
    color: var(--text2, #8fa3bf);
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .cl-line {
    width: 16px;
    height: 2px;
    border-radius: 2px;
  }
</style>